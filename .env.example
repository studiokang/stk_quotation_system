# ──────────────────────────────────────
# Database
# ──────────────────────────────────────
# Local
DATABASE_URL="postgresql://postgres:password@localhost:5432/survey_quote"

# Supabase (앱·Vercel): 보통 Transaction Pooler (예: :6543, pgbouncer/ssl 쿼리)
# DATABASE_URL="postgresql://postgres.xxx:PASSWORD@aws-0-xxx.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
#
# 마이그레이션(prisma migrate deploy)은 Direct(예: :5432)가 필요한 경우가 많음.
# 그때는 로컬 packages/db/.env 에만 Direct URL을 잠시 넣거나, Prisma directUrl 설정을 검토.
# 비밀번호에 @ ! 등 특수문자 → URL 인코딩 필수 (@ = %40 등)

# ──────────────────────────────────────
# JWT (min 32 characters) — 운영은 반드시 랜덤 생성값 사용
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# ──────────────────────────────────────
JWT_SECRET="your-secret-minimum-32-characters"

# ──────────────────────────────────────
# NextAuth (optional — 사용 시 min 32자, Vercel/turbo globalEnv와 동일 키)
# ──────────────────────────────────────
# NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars"

# ──────────────────────────────────────
# Supabase client (필수 — 브라우저용; Settings → API 의 Project URL / anon public)
# ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ──────────────────────────────────────
# Resend (선택 — 견적 메일 발송 시 필요, https://resend.com/api-keys)
#   비우면 빌드/런타임 검증 통과, 발송은 lib/quote/engine 에서 스킵
# ──────────────────────────────────────
# RESEND_API_KEY="re_your_key_here"
EMAIL_FROM="onboarding@resend.dev"

# ──────────────────────────────────────
# App
# ──────────────────────────────────────
# Vercel 빌드 시 env 검증 건너뛰기(선택) — Dashboard에도 동일 키로 추가 가능
# SKIP_ENV_VALIDATION=true
NEXT_PUBLIC_BASE_URL="https://stk-quotation-system-web.vercel.app"

# AI 기반 견적 파이프라인 (선택 — 변수 없음·false 동일)
USE_AI_QUOTE=false

# ──────────────────────────────────────
# Internal API — POST /api/quote/generate (min 32자, 설문 제출 후 서버 간 호출용)
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# ──────────────────────────────────────
INTERNAL_QUOTE_SECRET="your-internal-quote-secret-min-32-characters"

# ──────────────────────────────────────
# Upstash Redis (optional — rate limiting)
# ──────────────────────────────────────
# UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="your-upstash-token"
